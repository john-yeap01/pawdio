prefix=/usr/local
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: PortAudio
Description: Portable audio I/O
Version: 0.1.0

Libs: -L${libdir} -lportaudio
Libs.private:  -lm -lpthread -framework CoreAudio -framework AudioToolbox -framework AudioUnit -framework CoreFoundation -framework CoreServices
Cflags: -I${includedir}  -pthread -DPA_USE_COREAUDIO=1
Requires.private: 
